---
const metrics = [
  {
    icon: "M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    title: "Menos rechazos",
    description: "Cada solicitud sale completa y con lo que la aseguradora necesita.",
  },
  {
    icon: "M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z",
    title: "Cobro mas rapido",
    description: "Menos tiempo entre atencion y autorizacion.",
  },
  {
    icon: "M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z M15 12a3 3 0 11-6 0 3 3 0 016 0z",
    title: "Visibilidad total",
    description: "Estado en tiempo real de cada caso, sin perseguir informacion.",
  },
];
---

<section class="py-20 px-6 bg-zinc-50">
  <div class="max-w-5xl mx-auto">
    <p class="text-center text-lg text-zinc-500 mb-12">
      Los hospitales que gestionan bien sus autorizaciones cobran mas rapido y con menos friccion.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {metrics.map((m) => (
        <div class="text-center">
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-zinc-900 flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d={m.icon} />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-zinc-900 mb-2">{m.title}</h3>
          <p class="text-zinc-500">{m.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
