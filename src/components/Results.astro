---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import KurioLupaAnimated from "./KurioLupaAnimated.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

type LupaMode = "tilt" | "focus" | "scan-loop";
type InnerIcon = "checklist" | "check" | "chart-dollar";

const cards: Array<{
  title: string;
  description: string;
  lupaMode: LupaMode;
  innerIcon: InnerIcon;
}> = [
  {
    title: t("results.card1.title"),
    description: t("results.card1.body"),
    lupaMode: "tilt",
    innerIcon: "checklist",
  },
  {
    title: t("results.card2.title"),
    description: t("results.card2.body"),
    lupaMode: "focus",
    innerIcon: "check",
  },
  {
    title: t("results.card3.title"),
    description: t("results.card3.body"),
    lupaMode: "scan-loop",
    innerIcon: "chart-dollar",
  },
];
---

<section class="py-20 px-6 bg-zinc-50">
  <div class="max-w-5xl mx-auto">
    <p class="text-center text-lg text-zinc-500 mb-12">
      {t("results.intro")}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {cards.map((card) => (
        <div class="text-center">
          <div class="h-16 mx-auto mb-4 flex items-center justify-center">
            <KurioLupaAnimated
              size={56}
              mode={card.lupaMode}
              innerIcon={card.innerIcon}
            />
          </div>
          <h3 class="text-lg font-semibold text-zinc-900 mb-2">{card.title}</h3>
          <p class="text-zinc-500">{card.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
