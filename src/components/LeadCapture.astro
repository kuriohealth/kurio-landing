<section id="solicitar-acceso" class="py-20 px-6">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl font-bold text-zinc-900 mb-4">
      Quieres ver como funciona con tus propias aseguradoras?
    </h2>
    <p class="text-zinc-500 mb-10">
      Agenda una demo personalizada para tu hospital.
    </p>

    <!-- Tally form embed placeholder -->
    <!-- Replace data-tally-src with your actual Tally form URL -->
    <div class="bg-zinc-50 rounded-2xl p-8 border border-zinc-200">
      <iframe
        data-tally-src="https://tally.so/embed/ja74G4?alignLeft=1&hideTitle=1&transparentBackground=1"
        loading="lazy"
        width="100%"
        height="400"
        frameborder="0"
        marginheight="0"
        marginwidth="0"
        title="Solicitar acceso a Kurio"
        class="rounded-lg"
      ></iframe>
      <script src="https://tally.so/widgets/embed.js"></script>

      <!-- Fallback until Tally form is created -->
      <noscript>
        <p class="text-zinc-500">
          Escribenos a <a href="mailto:hola@kurio.health" class="text-zinc-900 underline">hola@kurio.health</a>
        </p>
      </noscript>
    </div>
  </div>
</section>
