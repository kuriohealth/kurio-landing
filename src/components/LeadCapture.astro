---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="solicitar-acceso" class="py-20 px-6">
  <div class="max-w-2xl mx-auto text-center">
    <div class="flex justify-center mb-4">
      <span class="k-eyebrow">{t("lead.eyebrow")}</span>
    </div>
    <h2 class="text-3xl font-bold text-zinc-900 mb-4">
      {t("lead.title")}
    </h2>
    <p class="text-zinc-500 mb-10">
      {t("lead.subtitle")}
    </p>

    <!-- Tally form embed — height is driven by Tally's embed.js postMessage
         resize via dynamicHeight=1; the inline height is just a first-paint
         placeholder so layout doesn't jump before the script runs. -->
    <div class="bg-zinc-50 rounded-2xl p-8 border border-zinc-200">
      <iframe
        data-tally-src="https://tally.so/embed/ja74G4?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
        loading="lazy"
        width="100%"
        height="276"
        frameborder="0"
        marginheight="0"
        marginwidth="0"
        title={t("lead.iframeTitle")}
        class="tally-iframe block w-full rounded-lg"
      ></iframe>
      <script async src="https://tally.so/widgets/embed.js"></script>

      <noscript>
        <p class="text-zinc-500">
          {t("lead.noscript")} <a href="mailto:hello@kurio.health" class="text-zinc-900 underline">hello@kurio.health</a>
        </p>
      </noscript>
    </div>

    <style>
      .tally-iframe {
        height: auto;
        min-height: 276px;
      }
    </style>
  </div>
</section>
