---
/**
 * Kurio's lupa (magnifying glass) — brand mark for the landing page.
 *
 * This is the **static** version of the agent's lupa. The interactive,
 * state-driven version (idle / processing / found) lives in the main app
 * where the agent actually runs. On the landing page there's no agent
 * activity to represent, so the lupa is purely the brand mark — same
 * silhouette as the prior /images/icon.png, just vectorized so it
 * matches the app and scales cleanly.
 *
 * Props:
 *   size  — pixel width/height (square). Default 32.
 *   class — extra CSS classes appended to the wrapper span.
 */
export interface Props {
  size?: number;
  class?: string;
}

const { size = 32, class: className = "" } = Astro.props;
---

<span
  class:list={["kurio-lupa", className]}
  style={`width: ${size}px; height: ${size}px;`}
  role="img"
  aria-label="Kurio"
>
  <svg viewBox="0 0 32 32" fill="none" width={size} height={size}>
    <circle cx="13" cy="13" r="9" stroke="currentColor" stroke-width="2.2" />
    <line
      x1="20"
      y1="20"
      x2="27"
      y2="27"
      stroke="currentColor"
      stroke-width="2.2"
      stroke-linecap="round"
    />
  </svg>
</span>

<style>
  .kurio-lupa {
    display: inline-block;
    color: #6D4FE8; /* Kurio brand purple; matches the in-app KurioLupa. */
    flex-shrink: 0;
    line-height: 0;
  }
  .kurio-lupa svg {
    display: block;
  }
</style>
