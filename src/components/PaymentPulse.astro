  @keyframes barCerrado {
    0%, 47%  { width: 55%; }
    51%      { width: 72%; }
    58%, 99% { width: 72%; }
    100%     { width: 55%; }
  }
  @keyframes floatCerrado {
    0%, 48% { opacity: 0; transform: translate(-50%, 4px); }
    51%     { opacity: 1; transform: translate(-50%, -12px); }
    56%     { opacity: 0; transform: translate(-50%, -24px); }
    57%, 100% { opacity: 0; }
  }

  /* === Traveling fajo de documentos ===================================== */
  .pulse-folder {
    position: absolute;
    width: 44px; height: 52px;
    pointer-events: none;
    opacity: 0;
    z-index: 3;
    animation: folderTravel var(--pulse-duration) linear infinite;
  }
  .pulse-doc {
    position: absolute;
    width: 32px; height: 40px;
    background: var(--k-bg);
    border: 1px solid var(--k-line);
    border-radius: 4px;
    box-shadow: 0 4px 10px -4px rgba(0,0,0,0.18), 0 2px 4px -2px rgba(0,0,0,0.06);
  }
  .pulse-doc--back   { top: 6px; left: 8px; transform: rotate(10deg); }
  .pulse-doc--mid    { top: 3px; left: 4px; transform: rotate(-8deg); }
  .pulse-doc--front  {
    top: 0; left: 0; transform: rotate(2deg);
    padding: 5px; display: flex; flex-direction: column; gap: 3px;
  }
  .pulse-doc--front::before {
    content: ''; width: 14px; height: 2px;
    background: var(--k-ink); opacity: 0.55;
    border-radius: 1px; margin-bottom: 2px;
  }
  .pulse-doc-line { height: 1.5px; background: var(--k-line); border-radius: 1px; }
  .pulse-doc-line:nth-child(2) { width: 90%; }
  .pulse-doc-line:nth-child(3) { width: 70%; }
  .pulse-doc-line:nth-child(4) { width: 80%; }

  /* Stack growth: Borrador = 1 doc, En curso = +mid + back fly in from
     below with arc + overshoot. */
  .pulse-doc--front { opacity: 1; }
  .pulse-doc--mid {
    opacity: 0;
    animation: midAppear var(--pulse-duration) linear infinite;
  }
  .pulse-doc--back {
    opacity: 0;
    animation: backAppear var(--pulse-duration) linear infinite;
  }
  @keyframes midAppear {
    0%, 12% { opacity: 0; transform: rotate(-22deg) translateY(50px); animation-timing-function: ease-out; }
    14%     { opacity: 0.5; transform: rotate(-18deg) translateY(28px); animation-timing-function: ease-in-out; }
    16%     { opacity: 1; transform: rotate(-12deg) translateY(-6px); animation-timing-function: ease-in; }
    18%     { opacity: 1; transform: rotate(-8deg) translateY(0); }
    100%    { opacity: 1; transform: rotate(-8deg) translateY(0); }
  }
  @keyframes backAppear {
    0%, 15% { opacity: 0; transform: rotate(24deg) translateY(50px); animation-timing-function: ease-out; }
    17%     { opacity: 0.5; transform: rotate(20deg) translateY(28px); animation-timing-function: ease-in-out; }
    19%     { opacity: 1; transform: rotate(14deg) translateY(-6px); animation-timing-function: ease-in; }
    21%     { opacity: 1; transform: rotate(10deg) translateY(0); }
    100%    { opacity: 1; transform: rotate(10deg) translateY(0); }
  }

  /* Fajo travel: ease-out for lifts (snappy takeoff), ease-in for
     landings (settle into column). Esperando lift is HIGH + Esperando
     dwell is LONG, so the visit isn't perceived as skipped. */
  @keyframes folderTravel {
    0%  { opacity: 0; left: 10%; top: 55%; transform: translate(-50%, -50%) rotate(-6deg); animation-timing-function: ease-out; }
    4%  { opacity: 1; left: 10%; top: 50%; transform: translate(-50%, -50%) rotate(0deg); animation-timing-function: ease-in-out; }
    8%  { opacity: 1; left: 10%; top: 50%; transform: translate(-50%, -50%) rotate(-2deg); }
    12% { opacity: 1; left: 10%; top: 50%; transform: translate(-50%, -50%) rotate(2deg); animation-timing-function: ease-out; }
    13% { opacity: 1; left: 16%; top: 40%; transform: translate(-50%, -50%) rotate(8deg); animation-timing-function: ease-in; }
    14% { opacity: 1; left: 30%; top: 50%; transform: translate(-50%, -50%) rotate(-3deg); animation-timing-function: ease-in-out; }
    18% { opacity: 1; left: 30%; top: 50%; transform: translate(-50%, -50%) rotate(2deg); }
    22% { opacity: 1; left: 30%; top: 50%; transform: translate(-50%, -50%) rotate(-2deg); animation-timing-function: ease-out; }
    23% { opacity: 1; left: 36%; top: 40%; transform: translate(-50%, -50%) rotate(8deg); animation-timing-function: ease-in; }
    24% { opacity: 1; left: 50%; top: 50%; transform: translate(-50%, -50%) rotate(-3deg); animation-timing-function: ease-in-out; }
    28% { opacity: 1; left: 50%; top: 50%; transform: translate(-50%, -50%) rotate(2deg); }
    32% { opacity: 1; left: 50%; top: 50%; transform: translate(-50%, -50%) rotate(-2deg); animation-timing-function: ease-out; }
    33% { opacity: 1; left: 58%; top: 28%; transform: translate(-50%, -50%) rotate(12deg); animation-timing-function: ease-in; }
    34% { opacity: 1; left: 70%; top: 50%; transform: translate(-50%, -50%) rotate(-5deg); animation-timing-function: ease-in-out; }
    38% { opacity: 1; left: 70%; top: 50%; transform: translate(-50%, -50%) rotate(2deg); }
    42% { opacity: 1; left: 70%; top: 50%; transform: translate(-50%, -50%) rotate(-3deg); }
    46% { opacity: 1; left: 70%; top: 50%; transform: translate(-50%, -50%) rotate(1deg); animation-timing-function: ease-out; }
    47% { opacity: 1; left: 78%; top: 38%; transform: translate(-50%, -50%) rotate(9deg); animation-timing-function: ease-in; }
    48% { opacity: 1; left: 90%; top: 50%; transform: translate(-50%, -50%) rotate(-2deg); }
    52% { opacity: 1; left: 90%; top: 50%; transform: translate(-50%, -50%) rotate(0deg); }
    54% { opacity: 0; left: 90%; top: 54%; transform: translate(-50%, -50%) rotate(4deg); }
    100% { opacity: 0; left: 10%; top: 55%; transform: translate(-50%, -50%) rotate(-6deg); }
  }

  /* "?" tag on fajo while in Esperando — orange badge top-right of folder */
  .pulse-folder-tag {
    position: absolute; top: -8px; right: -10px;
    width: 18px; height: 18px; border-radius: 50%;
    background: var(--k-status-responded-fg); color: #fff;
