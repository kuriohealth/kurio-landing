  }

  /* === Coin burst — 3 green Q discs fan out from Cerrado ============== */
  .pulse-coin-burst {
    position: absolute; left: 90%; top: 50%; width: 0; height: 0;
    transform: translate(-50%, -50%); pointer-events: none; z-index: 4;
