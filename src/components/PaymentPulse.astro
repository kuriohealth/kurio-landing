---
/**
 * "Pulso del cobro" — a 18s loop showing post-send financial visibility:
 *
 *   Fajo de documentos → Borrador → En curso → Enviado → Esperando → Cerrado
 *                                                  ↑ airplane     ↑ coin burst
 *
 * Replaces the static HowItWorks section. Together with InAction (which
 * covers assembly: agent organizes + verifies + sends), this section
 * covers the second half of the agent's work (tracks + visualizes
 * payment) — the two animations bookend the full lifecycle.
 *
 * Insurers cycle on a 54s mega-loop (3× the main 18s loop): one insurer's
 * data shown per full main loop, then swap. So Aurora's journey plays out
 * fully → swap → Plenitud → swap → Norte → loop back.
 *
 * Reuses kit primitives: .k-eyebrow, .k-headline-accent, .k-status-pill
 * (with all variants — including --responded for Esperando info).
 * Demo content stays in Spanish on both ES and EN pages — same rule as
 * InAction (the product runs in Spanish for LATAM).
 */
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-20 px-6 pulse-section">
  <div class="max-w-6xl mx-auto">
    <header class="pulse-header">
      <div>
        <span class="k-eyebrow">{t("pulse.eyebrow")}</span>
        <h2 class="pulse-h">
          {t("pulse.headline.lead")}<br>
          {t("pulse.headline.middle")} <em class="k-headline-accent">{t("pulse.headline.accent")}</em>
        </h2>
      </div>
      <p class="pulse-sublede">{t("pulse.sublede")}</p>
    </header>

    <div class="pulse-stage">

      <!-- Insurer chips (synthetic names, never real competitors) -->
      <div class="pulse-chips">
        <span class="pulse-chip pulse-chip--anchor">Todas</span>
        <span class="pulse-chip pulse-chip--A is-cycling">Aseguradora Aurora</span>
        <span class="pulse-chip pulse-chip--B is-cycling">Aseguradora Plenitud</span>
        <span class="pulse-chip pulse-chip--C is-cycling">Aseguradora Norte</span>
      </div>

      <!-- 5 stage columns + traveling fajo + paid pop overlay -->
      <div class="pulse-stages">

        <div class="pulse-col pulse-col-borrador">
          <span class="k-status-pill k-status-pill--pending">Borrador</span>
          <span class="pulse-count">
            <span class="pulse-data pulse-data--aurora">
              <span class="pulse-borrador-base">5</span>
              <span class="pulse-borrador-up">6</span>
            </span>
            <span class="pulse-data pulse-data--plenitud">
              <span class="pulse-borrador-base">8</span>
              <span class="pulse-borrador-up">9</span>
            </span>
            <span class="pulse-data pulse-data--norte">
              <span class="pulse-borrador-base">3</span>
              <span class="pulse-borrador-up">4</span>
            </span>
          </span>
          <span class="pulse-count-label">casos</span>
          <div class="pulse-folder-slot"></div>
          <div class="pulse-bar-row">
            <span class="pulse-bar-floater">+Q</span>
            <div class="pulse-bar-track"><div class="pulse-bar-fill"></div></div>
            <span class="pulse-bar-unit">Q</span>
          </div>
        </div>

        <div class="pulse-col pulse-col-encurso">
          <span class="k-status-pill k-status-pill--progress">En curso</span>
          <span class="pulse-count">
            <span class="pulse-data pulse-data--aurora">
              <span class="pulse-encurso-base">12</span>
              <span class="pulse-encurso-up">13</span>
            </span>
            <span class="pulse-data pulse-data--plenitud">
              <span class="pulse-encurso-base">14</span>
              <span class="pulse-encurso-up">15</span>
            </span>
            <span class="pulse-data pulse-data--norte">
              <span class="pulse-encurso-base">9</span>
              <span class="pulse-encurso-up">10</span>
            </span>
          </span>
          <span class="pulse-count-label">casos</span>
          <div class="pulse-folder-slot"></div>
          <div class="pulse-bar-row">
            <span class="pulse-bar-floater">+Q</span>
            <div class="pulse-bar-track"><div class="pulse-bar-fill"></div></div>
            <span class="pulse-bar-unit">Q</span>
          </div>
        </div>

        <div class="pulse-col pulse-col-enviado">
          <span class="k-status-pill k-status-pill--sent">Enviado</span>
          <span class="pulse-count">
            <span class="pulse-data pulse-data--aurora">
              <span class="pulse-enviado-base">24</span>
              <span class="pulse-enviado-up">25</span>
            </span>
            <span class="pulse-data pulse-data--plenitud">
              <span class="pulse-enviado-base">28</span>
              <span class="pulse-enviado-up">29</span>
            </span>
            <span class="pulse-data pulse-data--norte">
              <span class="pulse-enviado-base">18</span>
              <span class="pulse-enviado-up">19</span>
            </span>
          </span>
          <span class="pulse-count-label">casos</span>
          <div class="pulse-folder-slot"></div>
          <div class="pulse-bar-row">
            <span class="pulse-bar-floater">+Q</span>
            <div class="pulse-bar-track"><div class="pulse-bar-fill"></div></div>
            <span class="pulse-bar-unit">Q</span>
          </div>
        </div>

        <div class="pulse-col pulse-col-esperando">
          <span class="k-status-pill k-status-pill--responded">Esperando info</span>
          <span class="pulse-count">
            <span class="pulse-data pulse-data--aurora">
              <span class="pulse-esperando-base">8</span>
              <span class="pulse-esperando-up">9</span>
            </span>
            <span class="pulse-data pulse-data--plenitud">
              <span class="pulse-esperando-base">12</span>
              <span class="pulse-esperando-up">13</span>
            </span>
            <span class="pulse-data pulse-data--norte">
              <span class="pulse-esperando-base">5</span>
              <span class="pulse-esperando-up">6</span>
            </span>
          </span>
          <span class="pulse-count-label">casos</span>
          <div class="pulse-folder-slot"></div>
          <div class="pulse-bar-row">
            <span class="pulse-bar-floater">+Q</span>
            <div class="pulse-bar-track"><div class="pulse-bar-fill"></div></div>
            <span class="pulse-bar-unit">Q</span>
          </div>
        </div>

        <div class="pulse-col pulse-col-cerrado">
          <span class="k-status-pill k-status-pill--ready">Cerrado</span>
          <span class="pulse-count">
            <span class="pulse-data pulse-data--aurora">
              <span class="pulse-cerrado-base">156</span>
              <span class="pulse-cerrado-up">157</span>
            </span>
            <span class="pulse-data pulse-data--plenitud">
              <span class="pulse-cerrado-base">210</span>
              <span class="pulse-cerrado-up">211</span>
            </span>
            <span class="pulse-data pulse-data--norte">
              <span class="pulse-cerrado-base">98</span>
              <span class="pulse-cerrado-up">99</span>
            </span>
          </span>
          <span class="pulse-count-label">casos</span>
          <div class="pulse-folder-slot"></div>
          <div class="pulse-bar-row">
            <span class="pulse-bar-floater">+Q</span>
            <div class="pulse-bar-track"><div class="pulse-bar-fill"></div></div>
            <span class="pulse-bar-unit">Q</span>
          </div>
        </div>

        <!-- Folder (fajo): full journey, stack builds in En curso,
             airplane in Enviado, ? tag in Esperando, coin burst in Cerrado -->
        <span class="pulse-folder" aria-hidden="true">
          <span class="pulse-doc pulse-doc--back"></span>
          <span class="pulse-doc pulse-doc--mid"></span>
          <span class="pulse-doc pulse-doc--front">
            <span class="pulse-doc-line"></span>
            <span class="pulse-doc-line"></span>
            <span class="pulse-doc-line"></span>
          </span>
          <span class="pulse-folder-tag" aria-hidden="true">?</span>
        </span>

        <!-- Paper airplane — fires from Enviado when fajo lands.
             Same SVG + choreography as InAction's airplaneSent. -->
        <div class="pulse-airplane" aria-hidden="true">
          <div class="pulse-airplane-inner">
            <svg viewBox="0 0 24 24">
              <line x1="22" y1="2" x2="11" y2="13"/>
              <polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
          </div>
        </div>

        <!-- Coin burst — 3 green Q discs fan out from Cerrado when fajo
             lands. This IS the "money in" moment (no number, just the
             visual celebration). -->
        <div class="pulse-coin-burst" aria-hidden="true">
          <span class="pulse-coin pulse-coin--1">Q</span>
          <span class="pulse-coin pulse-coin--2">Q</span>
          <span class="pulse-coin pulse-coin--3">Q</span>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  /* All PaymentPulse-specific styling. Loop durations and per-stage
     timings are documented inline next to their keyframes. */
  .pulse-section {
    --pulse-duration: 18s;
  }

  /* === Header ============================================================ */
  .pulse-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 40px;
    padding: 0 4px;
  }
  .pulse-header .k-eyebrow {
    margin-bottom: 18px;
  }
  .pulse-h {
    font-size: clamp(28px, 4.2vw, 46px);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--k-ink);
    max-width: 620px;
  }
  .pulse-sublede {
    font-size: 14px;
    color: var(--k-ink-soft);
    line-height: 1.5;
    max-width: 280px;
    text-align: right;
  }

  /* === Stage card ======================================================== */
  .pulse-stage {
    background: var(--k-bg);
    border: 1px solid var(--k-line);
    border-radius: var(--k-radius-xl);
    padding: 32px 32px 36px;
    position: relative;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.8) inset,
      0 24px 48px -24px rgba(24, 24, 27, 0.10),
      0 2px 8px -2px rgba(24, 24, 27, 0.04);
  }
  .pulse-stage::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--k-line-soft) 1px, transparent 1px),
      linear-gradient(90deg, var(--k-line-soft) 1px, transparent 1px);
    background-size: 32px 32px;
    background-position: -1px -1px;
    mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
    pointer-events: none;
    border-radius: var(--k-radius-xl);
  }
  .pulse-stage > * { position: relative; z-index: 1; }

  /* === Insurer chips (cycle on 54s, one per main loop) =================== */
  .pulse-chips {
    display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 28px;
    align-items: center;
  }
  .pulse-chip {
    font-family: "Inter", sans-serif; font-size: 12px; font-weight: 500;
    padding: 6px 12px; border-radius: 9999px;
    background: var(--k-bg-subtle); color: var(--k-ink-soft);
    border: 1px solid transparent;
    transition: background 0.4s ease, color 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
    white-space: nowrap;
  }
  .pulse-chip--anchor { background: var(--k-ink); color: #fff; }
  .pulse-chip.is-cycling {
    animation-duration: 54s;
    animation-iteration-count: infinite;
    animation-timing-function: linear;
  }
  .pulse-chip--A.is-cycling { animation-name: chipActiveA; }
  .pulse-chip--B.is-cycling { animation-name: chipActiveB; }
  .pulse-chip--C.is-cycling { animation-name: chipActiveC; }
  @keyframes chipActiveA {
    0%, 32%   { background: var(--k-purple-soft); color: var(--k-purple); border-color: var(--k-purple); box-shadow: 0 0 0 3px rgba(109, 79, 232, 0.10); }
    33%, 99%  { background: var(--k-bg-subtle); color: var(--k-ink-soft); border-color: transparent; box-shadow: none; }
    100%      { background: var(--k-purple-soft); color: var(--k-purple); border-color: var(--k-purple); box-shadow: 0 0 0 3px rgba(109, 79, 232, 0.10); }
  }
  @keyframes chipActiveB {
    0%, 33%   { background: var(--k-bg-subtle); color: var(--k-ink-soft); border-color: transparent; box-shadow: none; }
    34%, 65%  { background: var(--k-purple-soft); color: var(--k-purple); border-color: var(--k-purple); box-shadow: 0 0 0 3px rgba(109, 79, 232, 0.10); }
    66%, 100% { background: var(--k-bg-subtle); color: var(--k-ink-soft); border-color: transparent; box-shadow: none; }
  }
  @keyframes chipActiveC {
    0%, 66%   { background: var(--k-bg-subtle); color: var(--k-ink-soft); border-color: transparent; box-shadow: none; }
    67%, 99%  { background: var(--k-purple-soft); color: var(--k-purple); border-color: var(--k-purple); box-shadow: 0 0 0 3px rgba(109, 79, 232, 0.10); }
    100%      { background: var(--k-bg-subtle); color: var(--k-ink-soft); border-color: transparent; box-shadow: none; }
  }

  /* === 5 stage columns ===================================================
     Single visit per loop. Loop timeline (% of 18s):
       Borrador  04-12% → glow
       En curso  14-22% → glow + stack-growth animation
       Enviado   24-32% → glow + airplane fires
       Esperando 34-46% → strong glow + ? tag on folder
       Cerrado   48-60% → glow + coin burst, stays elevated until loop end */
  .pulse-stages {
    position: relative;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
    min-height: 240px;
  }
  .pulse-col {
    background: var(--k-bg);
    border: 1px solid var(--k-line);
    border-radius: var(--k-radius-lg);
    padding: 14px 12px 16px;
    display: flex; flex-direction: column; align-items: center;
    text-align: center; position: relative;
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
    animation-duration: var(--pulse-duration);
    animation-iteration-count: infinite;
    animation-timing-function: ease-in-out;
  }
  .pulse-col-borrador  { animation-name: colGlowBorrador; }
  .pulse-col-encurso   { animation-name: colGlowEnCurso; }
  .pulse-col-enviado   { animation-name: colGlowEnviado; }
  .pulse-col-esperando { animation-name: colGlowEsperando; }
  .pulse-col-cerrado   { animation-name: colGlowCerrado; }

  @keyframes colGlowBorrador {
    0%, 3%    { border-color: var(--k-line); box-shadow: none; }
    4%, 12%   { border-color: var(--k-status-pending-fg); box-shadow: 0 0 0 3px var(--k-status-pending-bg); }
    14%, 100% { border-color: var(--k-line); box-shadow: none; }
  }
  @keyframes colGlowEnCurso {
    0%, 13%   { border-color: var(--k-line); box-shadow: none; }
    14%, 22%  { border-color: var(--k-status-progress-fg); box-shadow: 0 0 0 3px var(--k-status-progress-bg); }
    24%, 100% { border-color: var(--k-line); box-shadow: none; }
  }
  @keyframes colGlowEnviado {
    0%, 23%   { border-color: var(--k-line); box-shadow: none; }
    24%, 32%  { border-color: var(--k-status-sent-fg); box-shadow: 0 0 0 3px var(--k-status-sent-bg); }
    34%, 100% { border-color: var(--k-line); box-shadow: none; }
  }
  @keyframes colGlowEsperando {
    0%, 33%   { border-color: var(--k-line); box-shadow: none; }
    34%, 46%  { border-color: var(--k-status-responded-fg); box-shadow: 0 0 0 4px var(--k-status-responded-bg), 0 0 16px -2px rgba(194, 65, 12, 0.25); }
    48%, 100% { border-color: var(--k-line); box-shadow: none; }
  }
  @keyframes colGlowCerrado {
    0%, 47%   { border-color: var(--k-line); box-shadow: none; }
    48%, 60%  { border-color: var(--k-status-ready-fg); box-shadow: 0 0 0 4px var(--k-status-ready-bg), 0 0 16px -2px rgba(21, 128, 61, 0.25); }
    62%, 100% { border-color: var(--k-line); box-shadow: none; }
  }

  /* Status pill comes from kit; add a little bottom-margin within columns */
  .pulse-col .k-status-pill { margin-bottom: 12px; }

  /* === Counts (two-level opacity stacking) ============================== */
  /* Outer level (.pulse-data--xxx): 54s cycle — one insurer's data
     visible per main loop. Inner level (.pulse-xxx-base/.pulse-xxx-up):
     18s cycle — within active insurer, count fluctuates as folder visits. */
  .pulse-count {
    font-size: 30px;
    font-weight: 700;
    color: var(--k-ink);
    line-height: 1;
    font-variant-numeric: tabular-nums;
    margin-bottom: 4px;
    display: inline-grid;
  }
  .pulse-count > .pulse-data {
    grid-column: 1; grid-row: 1;
    display: inline-grid;
    opacity: 0;
    animation-duration: 54s;
    animation-iteration-count: infinite;
    animation-timing-function: linear;
  }
  .pulse-data > span {
    grid-column: 1; grid-row: 1; opacity: 0;
    animation-duration: var(--pulse-duration);
    animation-iteration-count: infinite;
    animation-timing-function: ease-in-out;
  }
  .pulse-data--aurora   { animation-name: dataAurora; }
  .pulse-data--plenitud { animation-name: dataPlenitud; }
  .pulse-data--norte    { animation-name: dataNorte; }
  @keyframes dataAurora {
    0%, 32%  { opacity: 1; }
    33%, 99% { opacity: 0; }
    100%     { opacity: 1; }
  }
  @keyframes dataPlenitud {
    0%, 33%  { opacity: 0; }
    34%, 65% { opacity: 1; }
    66%, 100% { opacity: 0; }
  }
  @keyframes dataNorte {
    0%, 66%  { opacity: 0; }
    67%, 99% { opacity: 1; }
    100%     { opacity: 0; }
  }

  .pulse-borrador-base  { animation-name: borradorBase; }
  .pulse-borrador-up    { animation-name: borradorUp; }
  @keyframes borradorBase { 0%, 3% { opacity: 1; } 4%, 12% { opacity: 0; } 14%, 100% { opacity: 1; } }
  @keyframes borradorUp   { 0%, 3% { opacity: 0; } 4%, 12% { opacity: 1; } 14%, 100% { opacity: 0; } }
  .pulse-encurso-base   { animation-name: encursoBase; }
  .pulse-encurso-up     { animation-name: encursoUp; }
  @keyframes encursoBase { 0%, 13% { opacity: 1; } 14%, 22% { opacity: 0; } 24%, 100% { opacity: 1; } }
  @keyframes encursoUp   { 0%, 13% { opacity: 0; } 14%, 22% { opacity: 1; } 24%, 100% { opacity: 0; } }
  .pulse-enviado-base   { animation-name: enviadoBase; }
  .pulse-enviado-up     { animation-name: enviadoUp; }
  @keyframes enviadoBase { 0%, 23% { opacity: 1; } 24%, 32% { opacity: 0; } 34%, 100% { opacity: 1; } }
  @keyframes enviadoUp   { 0%, 23% { opacity: 0; } 24%, 32% { opacity: 1; } 34%, 100% { opacity: 0; } }
  .pulse-esperando-base { animation-name: esperandoBase; }
  .pulse-esperando-up   { animation-name: esperandoUp; }
  @keyframes esperandoBase { 0%, 33% { opacity: 1; } 34%, 46% { opacity: 0; } 48%, 100% { opacity: 1; } }
  @keyframes esperandoUp   { 0%, 33% { opacity: 0; } 34%, 46% { opacity: 1; } 48%, 100% { opacity: 0; } }
  /* Cerrado: once the fajo lands at 48%, the +1 sticks until the loop wraps */
  .pulse-cerrado-base { animation-name: cerradoBase; }
  .pulse-cerrado-up   { animation-name: cerradoUp; }
  @keyframes cerradoBase { 0%, 47% { opacity: 1; } 48%, 100% { opacity: 0; } }
  @keyframes cerradoUp   { 0%, 47% { opacity: 0; } 48%, 99% { opacity: 1; } 100% { opacity: 0; } }

  .pulse-count-label {
    font-family: var(--k-font-mono); font-size: 9px;
    text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--k-ink-mute); margin-bottom: 10px;
  }
  .pulse-folder-slot { width: 44px; height: 50px; }

  /* === Bars (symbolic value, with floater "+Q" indicator) =============== */
  .pulse-bar-row {
    display: flex; align-items: center; gap: 6px; margin-top: 12px;
    width: 100%; position: relative;
  }
  .pulse-bar-track {
    flex: 1; height: 10px;
    background: var(--k-bg-subtle);
    border-radius: 5px;
    overflow: hidden;
    position: relative;
  }
  .pulse-bar-fill {
    height: 100%; border-radius: 5px; opacity: 0.9;
    animation-duration: var(--pulse-duration);
    animation-iteration-count: infinite;
    animation-timing-function: ease-in-out;
  }
  .pulse-bar-unit {
    font-family: var(--k-font-mono); font-size: 11px;
    color: var(--k-ink-soft); font-weight: 600;
  }
  .pulse-bar-floater {
    position: absolute; bottom: 12px; left: 50%;
    font-family: var(--k-font-mono); font-size: 11px; font-weight: 700;
    pointer-events: none; opacity: 0; transform: translate(-50%, 0);
    animation-duration: var(--pulse-duration);
    animation-iteration-count: infinite;
    animation-timing-function: ease-out;
  }

  .pulse-col-borrador .pulse-bar-fill {
    background: linear-gradient(180deg, var(--k-status-pending-fg) 0%, #82828A 100%);
    animation-name: barBorrador;
  }
  .pulse-col-borrador .pulse-bar-floater { color: var(--k-status-pending-fg); animation-name: floatBorrador; }
  @keyframes barBorrador { 0%, 3% { width: 14%; } 8% { width: 24%; } 14%, 100% { width: 14%; } }
  @keyframes floatBorrador {
    0%, 4% { opacity: 0; transform: translate(-50%, 4px); }
    8%     { opacity: 1; transform: translate(-50%, -10px); }
    13%    { opacity: 0; transform: translate(-50%, -22px); }
    14%, 100% { opacity: 0; }
  }
  .pulse-col-encurso .pulse-bar-fill {
    background: linear-gradient(180deg, var(--k-status-progress-fg) 0%, #92420A 100%);
    animation-name: barEnCurso;
  }
  .pulse-col-encurso .pulse-bar-floater { color: var(--k-status-progress-fg); animation-name: floatEnCurso; }
  @keyframes barEnCurso { 0%, 13% { width: 25%; } 18% { width: 38%; } 24%, 100% { width: 25%; } }
  @keyframes floatEnCurso {
    0%, 14% { opacity: 0; transform: translate(-50%, 4px); }
    18%     { opacity: 1; transform: translate(-50%, -10px); }
    23%     { opacity: 0; transform: translate(-50%, -22px); }
    24%, 100% { opacity: 0; }
  }
  .pulse-col-enviado .pulse-bar-fill {
    background: linear-gradient(180deg, var(--k-status-sent-fg) 0%, #1839A8 100%);
    animation-name: barEnviado;
  }
  .pulse-col-enviado .pulse-bar-floater { color: var(--k-status-sent-fg); animation-name: floatEnviado; }
  @keyframes barEnviado { 0%, 23% { width: 45%; } 28% { width: 60%; } 34%, 100% { width: 45%; } }
  @keyframes floatEnviado {
    0%, 24% { opacity: 0; transform: translate(-50%, 4px); }
    28%     { opacity: 1; transform: translate(-50%, -10px); }
    33%     { opacity: 0; transform: translate(-50%, -22px); }
    34%, 100% { opacity: 0; }
  }
  .pulse-col-esperando .pulse-bar-fill {
    background: linear-gradient(180deg, var(--k-status-responded-fg) 0%, #9A3309 100%);
    animation-name: barEsperando;
  }
  .pulse-col-esperando .pulse-bar-floater { color: var(--k-status-responded-fg); animation-name: floatEsperando; }
  @keyframes barEsperando { 0%, 33% { width: 12%; } 40% { width: 28%; } 46%, 100% { width: 12%; } }
  @keyframes floatEsperando {
    0%, 34% { opacity: 0; transform: translate(-50%, 4px); }
    40%     { opacity: 1; transform: translate(-50%, -10px); }
    45%     { opacity: 0; transform: translate(-50%, -22px); }
    46%, 100% { opacity: 0; }
  }
  /* Cerrado: bar STAYS at +1 width until loop wraps (case stays closed) */
  .pulse-col-cerrado .pulse-bar-fill {
    background: linear-gradient(180deg, var(--k-status-ready-fg) 0%, #0E5A2C 100%);
    animation-name: barCerrado;
