---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import LanguageToggle from "./LanguageToggle.astro";
import KurioLupa from "./KurioLupa.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const homePath = lang === "es" ? "/" : "/en/";
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-sm border-b border-zinc-200">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo — static lupa (brand mark). The animated, state-driven
         version of the lupa lives in the main app where the agent runs. -->
    <a href={homePath} class="flex items-center gap-2">
      <KurioLupa size={32} />
      <span class="text-xl font-semibold text-zinc-900">Kurio</span>
    </a>

    <!-- CTAs -->
    <div class="flex items-center gap-3">
      <LanguageToggle />
      <a
        href="https://app.kurio.health/login"
        class="text-sm font-medium text-zinc-600 hover:text-zinc-900 transition-colors hidden sm:block"
      >
        {t("nav.login")}
      </a>
      <a
        href="#solicitar-acceso"
        class="text-sm font-medium bg-zinc-900 text-white px-4 py-2 rounded-lg hover:bg-zinc-800 transition-colors"
      >
        {t("nav.request")}
      </a>
    </div>
  </div>
</nav>
