---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import KurioLupaAnimated from "./KurioLupaAnimated.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const steps = [
  {
    id: "organiza",
    number: "01",
    title: t("how.tab1.title"),
    description: t("how.tab1.body"),
    image: "/images/organiza.png",
  },
  {
    id: "verifica",
    number: "02",
    title: t("how.tab2.title"),
    description: t("how.tab2.body"),
    image: "/images/verifica.png",
    withLupa: true,
  },
  {
    id: "envia",
    number: "03",
    title: t("how.tab3.title"),
    description: t("how.tab3.body"),
    image: "/images/envia.png",
  },
  {
    id: "seguimiento",
    number: "04",
    title: t("how.tab4.title"),
    description: t("how.tab4.body"),
    image: "/images/seguimiento.png",
  },
];
---

<section class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold text-zinc-900 text-center mb-4">
      {t("how.title")}
    </h2>
    <p class="text-center text-zinc-500 mb-12 max-w-2xl mx-auto">
      {t("how.subtitle")}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {steps.map((step) => (
        <article
          data-step={step.id}
          class="bg-zinc-50 rounded-2xl p-6 md:p-8 flex flex-col gap-5"
        >
          <div class="aspect-[16/10] w-full overflow-hidden rounded-xl bg-white">
            <img
              src={step.image}
              alt={step.title}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>

          <div>
            <div class="flex items-center gap-2 mb-2">
              <span class="text-xs font-semibold tracking-wider text-zinc-400">
                {step.number}
              </span>
              {step.withLupa && (
                <KurioLupaAnimated
                  size={20}
                  mode="scanning-on-viewport"
                />
              )}
            </div>
            <h3 class="text-lg md:text-xl font-semibold text-zinc-900 mb-2">
              {step.title}
            </h3>
            <p class="text-zinc-500 leading-relaxed text-sm md:text-base">
              {step.description}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
