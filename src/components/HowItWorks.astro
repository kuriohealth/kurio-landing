---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import KurioLupaAnimated from "./KurioLupaAnimated.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

type LupaMode = "searching" | "discovering" | "breathing" | "monitoring";

const steps: Array<{
  id: string;
  number: string;
  title: string;
  description: string;
  image: string;
  lupaMode: LupaMode;
  lupaSize: number;
}> = [
  {
    id: "organiza",
    number: "01",
    title: t("how.tab1.title"),
    description: t("how.tab1.body"),
    image: "/images/organiza.png",
    lupaMode: "searching",
    lupaSize: 36,
  },
  {
    id: "verifica",
    number: "02",
    title: t("how.tab2.title"),
    description: t("how.tab2.body"),
    image: "/images/verifica.png",
    lupaMode: "discovering",
    lupaSize: 32,
  },
  {
    id: "envia",
    number: "03",
    title: t("how.tab3.title"),
    description: t("how.tab3.body"),
    image: "/images/envia.png",
    lupaMode: "breathing",
    lupaSize: 44,
  },
  {
    id: "seguimiento",
    number: "04",
    title: t("how.tab4.title"),
    description: t("how.tab4.body"),
    image: "/images/seguimiento.png",
    lupaMode: "monitoring",
    lupaSize: 32,
  },
];
---

<section class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <header class="text-center mb-12">
      <div class="flex justify-center mb-4">
        <span class="k-eyebrow">{t("how.eyebrow")}</span>
      </div>
      <h2 class="text-3xl font-bold text-zinc-900 mb-4">
        {t("how.title")}
      </h2>
      <p class="text-zinc-500 max-w-2xl mx-auto">
        {t("how.subtitle")}
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {steps.map((step) => (
        <article
          data-step={step.id}
          class="bg-zinc-50 rounded-2xl p-6 md:p-8 flex flex-col gap-5"
        >
          <div class="relative aspect-[16/10] w-full overflow-hidden rounded-xl bg-white">
            <img
              src={step.image}
              alt={step.title}
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
            />
            <KurioLupaAnimated mode={step.lupaMode} size={step.lupaSize} />
          </div>

          <div>
            <span class="k-step-number block mb-2">
              {step.number}
            </span>
            <h3 class="text-lg md:text-xl font-semibold text-zinc-900 mb-2">
              {step.title}
            </h3>
            <p class="text-zinc-500 leading-relaxed text-sm md:text-base">
              {step.description}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
