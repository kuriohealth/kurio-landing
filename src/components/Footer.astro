---
const year = new Date().getFullYear();
---

<footer class="py-10 px-6 border-t border-zinc-200">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2">
      <img src="/images/icon.png" alt="Kurio" class="h-6 w-6" />
      <span class="text-sm text-zinc-500">&copy; {year} Kurio. Todos los derechos reservados.</span>
    </div>
    <div class="flex items-center gap-6">
      <a href="https://app.kurio.health/login" class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors">
        Iniciar sesion
      </a>
      <a href="#solicitar-acceso" class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors">
        Solicitar acceso
      </a>
    </div>
  </div>
</footer>
