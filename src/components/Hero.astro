---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const headlines = [
  t("hero.headline.0"),
  t("hero.headline.1"),
  t("hero.headline.2"),
];
---

<section class="pt-32 pb-20 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <!-- Rotating headline -->
    <div class="h-16 sm:h-20 flex items-center justify-center mb-6">
      <h1
        id="hero-headline"
        class="text-4xl sm:text-5xl lg:text-6xl font-bold text-zinc-900 transition-opacity duration-500"
      >
        {headlines[0]}
      </h1>
    </div>

    <!-- Subtitle -->
    <p class="text-lg sm:text-xl text-zinc-500 max-w-2xl mx-auto mb-10 leading-relaxed">
      {t("hero.subtitle")}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://app.kurio.health/login"
        class="k-button k-button--secondary w-full sm:w-auto"
      >
        {t("nav.login")}
      </a>
      <a
        href="#solicitar-acceso"
        class="k-button k-button--primary w-full sm:w-auto"
      >
        {t("nav.request")}
      </a>
    </div>
  </div>
</section>

<script define:vars={{ headlines }}>
  let current = 0;
  const el = document.getElementById("hero-headline");

  setInterval(() => {
    if (!el) return;
    el.style.opacity = "0";
    setTimeout(() => {
      current = (current + 1) % headlines.length;
      el.textContent = headlines[current];
      el.style.opacity = "1";
    }, 400);
  }, 3000);
</script>
