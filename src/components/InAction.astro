---
/**
 * "Kurio in action" — a 16s loop showing the agent at work:
 *
 *   Patient journey events  →  Kurio agent (lupa scans)  →  Expediente builds itself
 *
 * Visual primitives that get reused elsewhere live in kurio-ui.css
 * (`.k-eyebrow`, `.k-tag-label`, `.k-status-pill`, `.k-banner`,
 * `.k-headline-accent`). InAction-specific code below owns the
 * stage layout and the 16s sequence keyframes.
 *
 * Demo content (medical case data) intentionally stays in Spanish on
 * both ES and EN pages — the product runs in Spanish for the LATAM
 * market, so the "live demo" is a faithful preview of what users see.
 */
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import KurioLupaAnimated from "./KurioLupaAnimated.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-20 px-6 inaction-section">
  <div class="max-w-6xl mx-auto">
    <header class="inaction-header">
      <div>
        <span class="k-eyebrow">{t("inaction.eyebrow")}</span>
        <h2 class="inaction-h">
          {t("inaction.headline.lead")}<br>
          <em class="k-headline-accent">{t("inaction.headline.accent")}</em>
        </h2>
      </div>
      <p class="sublede">{t("inaction.sublede")}</p>
    </header>

    <div class="stage">
      <div class="stage-grid">

        <!-- LEFT: Patient journey -->
        <div class="journey">
          <div class="k-tag-label k-tag-label--warm">
            {t("inaction.label.journey")}
          </div>
          <div class="journey-track">
            <div class="event e1">
              <div class="event-marker">
                <svg viewBox="0 0 24 24"><path d="M3 12h6l2-3 4 6 2-3h4"/></svg>
              </div>
              <div class="event-time">06:42 · Emergencia</div>
              <div class="event-title">Ingreso por dolor abdominal</div>
              <div class="event-detail">Mario González · 47 años</div>
            </div>
            <div class="event e2">
              <div class="event-marker">
                <svg viewBox="0 0 24 24"><path d="M9 3v6l-4 8a3 3 0 0 0 2.7 4h8.6A3 3 0 0 0 19 17l-4-8V3"/><path d="M8 3h8"/></svg>
              </div>
              <div class="event-time">08:15 · Laboratorio</div>
              <div class="event-title">Estudios solicitados</div>
              <div class="event-detail">Hemograma, ecografía abdominal</div>
            </div>
            <div class="event e3">
              <div class="event-marker">
                <svg viewBox="0 0 24 24"><path d="M3 18v-7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v7"/><path d="M3 18h18"/><path d="M8 9V6"/></svg>
              </div>
              <div class="event-time">11:30 · Hospitalización</div>
              <div class="event-title">Diagnóstico: apendicitis</div>
              <div class="event-detail">Indicación quirúrgica · ASA I</div>
            </div>
            <div class="event e4">
              <div class="event-marker">
                <svg viewBox="0 0 24 24"><path d="M12 2v6"/><path d="M9 5l3-3 3 3"/><circle cx="12" cy="14" r="6"/></svg>
              </div>
              <div class="event-time">14:00 · Quirófano</div>
              <div class="event-title">Apendicectomía laparoscópica</div>
              <div class="event-detail">Dr. Ramírez · Sala 3</div>
            </div>
          </div>
        </div>

        <!-- MIDDLE: Agent (lupa) + traveling docs -->
        <div class="flow">
          <div class="lupa-wrap">
            <KurioLupaAnimated mode="focus" size={40} />
          </div>

          <span class="lupa-glow g1"></span>
          <span class="lupa-glow g2"></span>
          <span class="lupa-glow g3"></span>
          <span class="lupa-glow g4"></span>

          <div class="doc d1">
            <span class="line"></span><span class="line"></span><span class="line"></span><span class="line"></span>
            <span class="doc-label">Nota de Ingreso</span>
          </div>
          <div class="doc d2">
            <span class="line"></span><span class="line"></span><span class="line"></span><span class="line"></span>
            <span class="doc-label">Resultados Lab</span>
          </div>
          <div class="doc d3">
            <span class="line"></span><span class="line"></span><span class="line"></span><span class="line"></span>
            <span class="doc-label">Evolución</span>
          </div>
          <div class="doc d4">
            <span class="line"></span><span class="line"></span><span class="line"></span><span class="line"></span>
            <span class="doc-label">Hoja Quirúrgica</span>
          </div>
        </div>

        <!-- RIGHT: Expediente builds itself -->
        <div class="expediente">
          <div class="k-tag-label k-tag-label--agent">
            {t("inaction.label.expediente")}
          </div>
          <div class="expediente-card">
            <div class="exp-header">
              <div>
                <div class="exp-id">EXP-2026-0142</div>
                <div class="exp-patient">Mario González · 47</div>
              </div>
              <div class="exp-status">
                <span class="k-status-pill k-status-pill--pending  status-state state-borrador">Borrador</span>
                <span class="k-status-pill k-status-pill--progress status-state state-encurso">En curso</span>
                <span class="k-status-pill k-status-pill--ready    status-state state-listo">Listo</span>
                <span class="k-status-pill k-status-pill--sent     status-state state-enviado">Enviado</span>
              </div>
            </div>

            <div class="exp-fields">
              <div class="field f1"><div class="field-label">Paciente</div><div class="field-value">Mario González</div></div>
              <div class="field f2"><div class="field-label">Fecha ingreso</div><div class="field-value">15·05·2026</div></div>
              <div class="field f3"><div class="field-label">Estudios</div><div class="field-value">Hemograma · Eco</div></div>
              <div class="field f4"><div class="field-label">Hallazgo</div><div class="field-value">Apéndice inflamado</div></div>
              <div class="field f5"><div class="field-label">Diagnóstico</div><div class="field-value">Apendicitis aguda</div></div>
              <div class="field f6"><div class="field-label">CIE-10</div><div class="field-value">K35.80</div></div>
              <div class="field f7"><div class="field-label">Procedimiento</div><div class="field-value">Apendicectomía lap.</div></div>
              <div class="field f8"><div class="field-label">Cirujano</div><div class="field-value">Dr. R. Ramírez</div></div>
            </div>

            <div class="exp-ready k-banner k-banner--ready">
              <div class="k-banner__icon">✓</div>
              <div>
                <div class="exp-ready-text"><strong>Listo para envío</strong> · Aseguradora</div>
                <div class="exp-ready-meta">Match de patrón · 94% confianza</div>
              </div>
            </div>

            <!-- Paper airplane — appears when status flips to "Enviado",
                 briefly hovers, then flies up-right out of the card. -->
            <div class="exp-airplane" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <line x1="22" y1="2" x2="11" y2="13"/>
                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
              </svg>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  /* InAction-specific timing only. All design tokens come from
     kurio-brand.css via :root (--k-purple, --k-status-*, --k-ink, etc.).
     The 16s loop: first ~12.5s is the document flow; the remaining
     ~3.5s lets the case file settle into Listo, then Enviado with
     the airplane fly-off, before the cycle resets to Borrador. */
  .inaction-section {
    --in-duration: 16s;
  }

  /* Header layout */
  .inaction-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 40px;
    padding: 0 4px;
  }
  /* k-eyebrow spacing within this section's header */
  .inaction-header .k-eyebrow {
    margin-bottom: 18px;
  }
  .inaction-h {
    font-size: clamp(28px, 4.2vw, 46px);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--k-ink);
    max-width: 620px;
  }
  .sublede {
    font-size: 14px;
    color: var(--k-ink-soft);
    line-height: 1.5;
    max-width: 280px;
    text-align: right;
  }

  /* Stage card */
  .stage {
    background: var(--k-bg);
    border: 1px solid var(--k-line);
    border-radius: var(--k-radius-xl);
    padding: 36px 28px;
    position: relative;
    /* No overflow: hidden — lets the paper airplane fly out of the
       card onto the section background. */
    box-shadow:
      0 1px 0 rgba(255,255,255,0.8) inset,
      0 24px 48px -24px rgba(24, 24, 27, 0.10),
      0 2px 8px -2px rgba(24, 24, 27, 0.04);
  }
  .stage::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--k-line-soft) 1px, transparent 1px),
      linear-gradient(90deg, var(--k-line-soft) 1px, transparent 1px);
    background-size: 32px 32px;
    background-position: -1px -1px;
    mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
    pointer-events: none;
  }
  .stage-grid {
    display: grid;
    grid-template-columns: 1fr 80px 1.2fr;
    gap: 24px;
    align-items: stretch;
    min-height: 440px;
    position: relative;
    z-index: 1;
  }

  /* k-tag-label spacing in both columns (journey + expediente) */
  .journey > .k-tag-label,
  .expediente > .k-tag-label {
    margin-bottom: 18px;
  }

  /* === LEFT: Patient journey === */
  .journey { position: relative; }
  .journey-track {
    position: relative;
    padding-left: 28px;
  }
  .journey-track::before {
    content: '';
    position: absolute;
    left: 11px; top: 14px; bottom: 14px;
    width: 1px;
    background: linear-gradient(to bottom, var(--k-status-progress-bg) 0%, var(--k-line) 100%);
  }
  .event {
    position: relative;
    margin-bottom: 22px;
    padding: 10px 14px 10px 4px;
    border-radius: 10px;
    transition: background 0.4s ease;
  }
  .event:last-child { margin-bottom: 0; }
  .event-marker {
    position: absolute;
    left: -28px;
    top: 14px;
    width: 24px; height: 24px;
    border-radius: 50%;
    background: var(--k-bg);
    border: 1.5px solid var(--k-line);
    display: grid;
    place-items: center;
    transition: all 0.4s ease;
  }
  .event-marker svg {
    width: 12px; height: 12px;
    stroke: var(--k-ink-mute);
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: stroke 0.4s ease;
  }
  .event-time {
    font-family: var(--k-font-mono);
    font-size: 10px;
    color: var(--k-ink-mute);
    letter-spacing: 0.04em;
  }
  .event-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--k-ink);
    margin-top: 2px;
  }
  .event-detail {
    font-size: 12px;
    color: var(--k-ink-soft);
    margin-top: 2px;
    line-height: 1.4;
  }

  .event.e1 { animation: eventActive var(--in-duration) ease-in-out infinite; animation-delay: 0s; }
  .event.e2 { animation: eventActive var(--in-duration) ease-in-out infinite; animation-delay: -13.2s; }
  .event.e3 { animation: eventActive var(--in-duration) ease-in-out infinite; animation-delay: -10.4s; }
  .event.e4 { animation: eventActive var(--in-duration) ease-in-out infinite; animation-delay: -7.6s; }
  @keyframes eventActive {
    0%, 5%   { background: transparent; }
    8%, 22%  { background: var(--k-status-progress-bg); }
    25%, 100%{ background: transparent; }
  }
  .event.e1 .event-marker { animation: markerActive var(--in-duration) ease-in-out infinite; animation-delay: 0s; }
  .event.e2 .event-marker { animation: markerActive var(--in-duration) ease-in-out infinite; animation-delay: -13.2s; }
  .event.e3 .event-marker { animation: markerActive var(--in-duration) ease-in-out infinite; animation-delay: -10.4s; }
  .event.e4 .event-marker { animation: markerActive var(--in-duration) ease-in-out infinite; animation-delay: -7.6s; }
  @keyframes markerActive {
    0%, 5%   { background: var(--k-bg); border-color: var(--k-line); }
    8%, 22%  { background: var(--k-status-progress-fg); border-color: var(--k-status-progress-fg); box-shadow: 0 0 0 4px var(--k-status-progress-bg); }
    25%, 100%{ background: var(--k-bg); border-color: var(--k-line); box-shadow: none; }
  }
  .event.e1 .event-marker svg { animation: iconActive var(--in-duration) ease-in-out infinite; animation-delay: 0s; }
  .event.e2 .event-marker svg { animation: iconActive var(--in-duration) ease-in-out infinite; animation-delay: -13.2s; }
  .event.e3 .event-marker svg { animation: iconActive var(--in-duration) ease-in-out infinite; animation-delay: -10.4s; }
  .event.e4 .event-marker svg { animation: iconActive var(--in-duration) ease-in-out infinite; animation-delay: -7.6s; }
  @keyframes iconActive {
    0%, 5%, 25%, 100% { stroke: var(--k-ink-mute); }
    8%, 22% { stroke: #ffffff; }
  }

  /* === MIDDLE: Agent + docs === */
  .flow {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .lupa-wrap {
    position: relative;
    z-index: 2;
  }

  .doc {
    position: absolute;
    /* Pin to .flow's top-left so translateY values in keyframes are
       measured from .flow's top (not from the flex-centered "static
       position"). */
    top: 0;
    left: 0;
    width: 64px;
    height: 80px;
    background: var(--k-bg);
    border: 1px solid var(--k-line);
    border-radius: 6px;
    padding: 6px;
    display: flex;
    flex-direction: column;
    gap: 3px;
    opacity: 0;
    box-shadow: 0 8px 24px -8px rgba(24, 24, 27, 0.18), 0 2px 4px rgba(24, 24, 27, 0.04);
  }
  .doc::before {
    content: '';
    width: 18px; height: 2px;
    background: var(--k-ink);
    opacity: 0.5;
    border-radius: 1px;
    margin-bottom: 2px;
  }
  .doc .line {
    height: 1.5px;
    background: var(--k-line);
    border-radius: 1px;
  }
  .doc .line:nth-child(2) { width: 90%; }
  .doc .line:nth-child(3) { width: 70%; }
  .doc .line:nth-child(4) { width: 85%; }
  .doc .line:nth-child(5) { width: 60%; }
  .doc-label {
    position: absolute;
    bottom: -16px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--k-font-mono);
    font-size: 9px;
    color: var(--k-ink-mute);
    white-space: nowrap;
    letter-spacing: 0.04em;
  }

  /* Each doc emerges from its corresponding event's marker height
     (--event-y, calibrated to actual measured marker centers:
     59 / 158 / 257 / 355 from .flow top, minus 40 to align doc center
     with marker center).
     Delays use a 2.8s stride so all four docs deliver within the
     first ~78% of the 16s cycle:
       d1 starts t=0,    delivered ~4.2s
       d2 starts t=2.8,  delivered ~7.0s
       d3 starts t=5.6,  delivered ~9.8s
       d4 starts t=8.4,  delivered ~12.6s  */
  .doc.d1 { --event-y: 19px;  animation: docTravel var(--in-duration) ease-in-out infinite; animation-delay: 0s; }
  .doc.d2 { --event-y: 118px; animation: docTravel var(--in-duration) ease-in-out infinite; animation-delay: -13.2s; }
  .doc.d3 { --event-y: 217px; animation: docTravel var(--in-duration) ease-in-out infinite; animation-delay: -10.4s; }
  .doc.d4 { --event-y: 315px; animation: docTravel var(--in-duration) ease-in-out infinite; animation-delay: -7.6s; }
  /* All four docs converge on the lupa at translateY=177 — measured
     lupa center is at Y=217 from .flow top; doc center (177 + 40 = 217)
     lands exactly on lupa center. */
  @keyframes docTravel {
    0%   { opacity: 0; transform: translate(-180px, var(--event-y)) scale(0.85) rotate(-6deg); }
    5%   { opacity: 1; transform: translate(-180px, var(--event-y)) scale(1) rotate(-6deg); }
    10%  { opacity: 1; transform: translate(-180px, var(--event-y)) scale(1) rotate(-6deg); }
    13%  { opacity: 1; transform: translate(-90px, calc((var(--event-y) + 177px) / 2)) scale(1.05) rotate(-2deg); }
    16%  { opacity: 1; transform: translate(8px, 177px) scale(1.08) rotate(0deg); filter: drop-shadow(0 0 0 var(--k-purple)); }
    19%  { transform: translate(8px, 177px) scale(1.08) rotate(0deg); filter: drop-shadow(0 0 14px rgba(109, 79, 232, 0.45)); }
    22%  { opacity: 1; transform: translate(80px, 177px) scale(0.95) rotate(4deg); }
    26%  { opacity: 0; transform: translate(180px, 177px) scale(0.6) rotate(8deg); }
    100% { opacity: 0; transform: translate(180px, 177px) scale(0.6); }
  }

  .lupa-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    margin-top: -20px;
    margin-left: -20px;
    width: 40px; height: 40px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(109, 79, 232, 0.45) 0%, transparent 70%);
    opacity: 0;
    pointer-events: none;
  }
  .lupa-glow.g1 { animation: scanFlash var(--in-duration) ease-in-out infinite; animation-delay: 0s; }
  .lupa-glow.g2 { animation: scanFlash var(--in-duration) ease-in-out infinite; animation-delay: -13.2s; }
  .lupa-glow.g3 { animation: scanFlash var(--in-duration) ease-in-out infinite; animation-delay: -10.4s; }
  .lupa-glow.g4 { animation: scanFlash var(--in-duration) ease-in-out infinite; animation-delay: -7.6s; }
  @keyframes scanFlash {
    0%, 16% { opacity: 0; transform: scale(1); }
    18%     { opacity: 1; transform: scale(1.6); }
    22%     { opacity: 0; transform: scale(2); }
    100%    { opacity: 0; }
  }

  /* === RIGHT: Expediente === */
  .expediente { position: relative; }
  .expediente-card {
    background: var(--k-bg);
    border: 1px solid var(--k-line);
    border-radius: var(--k-radius-lg);
    padding: 16px;
    position: relative;
    /* No overflow: hidden — lets the paper airplane fly free. */
    animation: cardReady var(--in-duration) ease-in-out infinite;
  }
  /* Card border tracks the status: green during Listo (79-88%),
     blue during Enviado (89-100%), neutral while docs are flowing.
     Colors come from the kit's status tokens. */
  @keyframes cardReady {
    0%, 78%   { box-shadow: 0 1px 2px rgba(24, 24, 27, 0.04); border-color: var(--k-line); }
    79%, 88%  { box-shadow: 0 0 0 4px var(--k-status-ready-bg), 0 12px 32px -12px rgba(21, 128, 61, 0.25); border-color: var(--k-status-ready-fg); }
    89%, 100% { box-shadow: 0 0 0 4px var(--k-status-sent-bg),  0 12px 32px -12px rgba(29, 78, 216, 0.25); border-color: var(--k-status-sent-fg); }
  }

  .exp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 12px;
    border-bottom: 1px dashed var(--k-line);
    margin-bottom: 14px;
  }
  .exp-id {
    font-family: var(--k-font-mono);
    font-size: 10px;
    color: var(--k-ink-mute);
    letter-spacing: 0.06em;
  }
  .exp-patient {
    font-size: 13px;
    font-weight: 500;
    color: var(--k-ink);
    margin-top: 2px;
  }

  /* Status pill cycling: each pill carries .k-status-pill (visual,
     from the kit) + .status-state (grid placement + animation)
     + .state-* (which keyframe to drive). The kit owns the visual,
     this file owns the cycle behavior. */
  .exp-status {
    display: inline-grid;
  }
  .status-state {
    grid-column: 1;
    grid-row: 1;
    opacity: 0;
    animation-duration: var(--in-duration);
    animation-iteration-count: infinite;
    animation-timing-function: ease-in-out;
  }
  .state-borrador { animation-name: statusBorrador; }
  .state-encurso  { animation-name: statusEnCurso; }
  .state-listo    { animation-name: statusListo; }
  .state-enviado  { animation-name: statusEnviado; }

  /* Sequence over 16s loop, synchronized to the document flow.
     Listo only appears AFTER d4 has been delivered (not when it
     starts traveling):
       Borrador  0-5%      (very brief — case empty before d1 emerges)
       En curso  6-78%     (d1 appears @ 5%, d4 delivered @ ~78%)
       Listo     79-88%    (case complete, green border, banner shows)
       Enviado   89-100%   (paper airplane flies out, blue border) */
  @keyframes statusBorrador {
    0%, 5%      { opacity: 1; }
    6%, 100%    { opacity: 0; }
  }
  @keyframes statusEnCurso {
    0%, 5%      { opacity: 0; }
    6%, 78%     { opacity: 1; }
    79%, 100%   { opacity: 0; }
  }
  @keyframes statusListo {
    0%, 78%     { opacity: 0; }
    79%, 88%    { opacity: 1; }
    89%, 100%   { opacity: 0; }
  }
  @keyframes statusEnviado {
    0%, 88%     { opacity: 0; }
    89%, 100%   { opacity: 1; }
  }

  .exp-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .field {
    background: #FAFAFA;
    border: 1px solid var(--k-line-soft);
    border-radius: var(--k-radius-md);
    padding: 9px 11px;
    opacity: 0.3;
    transform: translateY(4px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .field-label {
    font-family: var(--k-font-mono);
    font-size: 8.5px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--k-ink-mute);
    margin-bottom: 3px;
  }
  .field-value {
    font-size: 12px;
    color: var(--k-ink);
    font-weight: 500;
    line-height: 1.25;
  }
  .field.f1, .field.f2 { animation: fieldAppear var(--in-duration) ease-out infinite; animation-delay: 0s; }
  .field.f3, .field.f4 { animation: fieldAppear var(--in-duration) ease-out infinite; animation-delay: -13.2s; }
  .field.f5, .field.f6 { animation: fieldAppear var(--in-duration) ease-out infinite; animation-delay: -10.4s; }
