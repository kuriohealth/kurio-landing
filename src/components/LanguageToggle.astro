---
import { getLangFromUrl, getLocalizedPath, getOtherLang, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const otherLang = getOtherLang(lang);
const targetPath = getLocalizedPath(Astro.url.pathname, otherLang);
const t = useTranslations(lang);

// Label shows the OTHER language (what you'll switch to)
const label = otherLang === "en" ? "EN" : "ES";
---

<a
  href={targetPath}
  hreflang={otherLang}
  aria-label={t("toggle.aria")}
  class="text-sm font-medium text-zinc-500 hover:text-zinc-900 transition-colors px-2 py-1 border border-zinc-200 rounded-md"
>
  {label}
</a>
