---
/**
 * Animated counterpart to the static KurioLupa. Two layout families:
 *
 *   - Overlay modes (positioned absolutely on top of an illustration).
 *     Used in HowItWorks to narrate per-step agent activity.
 *       searching   → zigzag sweep ("looking through docs")
 *       discovering → quick pops at clustered points ("found it!")
 *       breathing   → strong centered pulse ("case is sent, watching")
 *       monitoring  → vertical zigzag ("scrolling through cases")
 *
 *   - Inline icon modes (rendered like a normal icon, no abs positioning).
 *     Used in Results cards (lupa over a secondary symbol = "agent
 *     examining X") and Solution quote (idle "agent is here" mark).
 *       tilt       → rotates ±7° ("comparing rules")
 *       focus      → strong scale pulse ("zooming in on the missing piece")
 *       scan-loop  → tiny elliptical orbit ("sweeping the data")
 *       idle       → soft scale pulse ("agent quietly present")
 *
 * `innerIcon` overlays a glyph inside the lupa's lens, so each Results
 * card reads as "the agent looking at [checklist | check | $-bars]".
 *
 * Animations are CSS-only and respect prefers-reduced-motion (collapses
 * to a static lupa).
 */
export interface Props {
  size?: number;
  mode:
    | "searching"
    | "discovering"
    | "breathing"
    | "monitoring"
    | "tilt"
    | "focus"
    | "scan-loop"
    | "idle";
  innerIcon?: "checklist" | "check" | "chart-dollar";
  class?: string;
}

const {
  size = 32,
  mode,
  innerIcon,
  class: className = "",
} = Astro.props;
---

<span
  class:list={["kurio-lupa-animated", `mode-${mode}`, className]}
  style={`width: ${size}px; height: ${size}px;`}
  data-mode={mode}
  role="img"
  aria-label="Kurio"
>
  <svg
    viewBox="0 0 32 32"
    fill="none"
    width={size}
    height={size}
    aria-hidden="true"
  >
    <g class="lupa-shape">
      <circle cx="13" cy="13" r="9" stroke="currentColor" stroke-width="2.4" />
      <line
        x1="20"
        y1="20"
        x2="27"
        y2="27"
        stroke="currentColor"
        stroke-width="2.4"
        stroke-linecap="round"
      />
    </g>

    {innerIcon && (
      <g class="lupa-inner">
        {innerIcon === "checklist" && (
          <g>
            <line x1="9.5" y1="11" x2="14" y2="11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            <line x1="9.5" y1="13" x2="16.2" y2="13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            <line x1="9.5" y1="15" x2="13.5" y2="15" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
          </g>
        )}

        {innerIcon === "check" && (
          <path
            d="M9.5 13.2 L12 15.6 L17 10.6"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            fill="none"
          />
        )}

        {innerIcon === "chart-dollar" && (
          <g>
            <rect x="9.6" y="14" width="1.3" height="3" rx="0.3" fill="currentColor" />
            <rect x="11.6" y="11.8" width="1.3" height="5.2" rx="0.3" fill="currentColor" />
            <text
              x="16.4"
              y="15.6"
              font-family="Inter, system-ui, sans-serif"
              font-size="6.5"
              font-weight="700"
              fill="currentColor"
              text-anchor="middle"
            >$</text>
          </g>
        )}
      </g>
    )}
  </svg>
</span>

<style>
  .kurio-lupa-animated {
    color: #6D4FE8;
    line-height: 0;
    pointer-events: none;
    filter: drop-shadow(0 2px 4px rgba(109, 79, 232, 0.35))
            drop-shadow(0 0 8px rgba(255, 255, 255, 0.6));
  }
  .kurio-lupa-animated svg {
    display: block;
  }
  /* Inner glyph rendered inside the lens reads as ink-on-paper —
     dark, slightly bolder strokes, decoupled from the lupa's purple. */
  .kurio-lupa-animated .lupa-inner {
    color: #18181B;
  }

  /* Overlay modes (used inside .relative image containers in HowItWorks). */
  .mode-searching,
  .mode-discovering,
  .mode-breathing,
  .mode-monitoring {
    position: absolute;
  }

  /* Inline icon modes (used in Results / Solution sections). */
  .mode-tilt,
  .mode-focus,
  .mode-scan-loop,
  .mode-idle {
    display: inline-block;
    transform-origin: 50% 50%;
  }
  /* Inline modes don't need the strong purple shadow — softer halo only. */
  .mode-tilt,
  .mode-focus,
  .mode-scan-loop,
  .mode-idle {
    filter: drop-shadow(0 1px 2px rgba(109, 79, 232, 0.18));
  }

  /* === overlay mode keyframes === */

  /* searching — zigzag over the document area */
  .mode-searching {
    top: 12%;
    left: 10%;
    animation: lupa-searching 6s ease-in-out infinite;
  }
  @keyframes lupa-searching {
    0%   { top: 12%;  left: 10%; }
    25%  { top: 22%;  left: 65%; }
    50%  { top: 55%;  left: 25%; }
    75%  { top: 68%;  left: 72%; }
    100% { top: 12%;  left: 10%; }
  }

  /* discovering — 5 quick "found it!" pops at clustered points */
  .mode-discovering {
    top: 22%;
    left: 28%;
    animation: lupa-discovering 6.5s steps(1, end) infinite;
  }
  .mode-discovering svg {
    opacity: 0;
    animation: lupa-discovering-pulse 1.3s ease-in-out infinite;
  }
  @keyframes lupa-discovering {
    0%, 100% { top: 22%; left: 28%; }
    20%      { top: 28%; left: 62%; }
    40%      { top: 58%; left: 38%; }
    60%      { top: 65%; left: 70%; }
    80%      { top: 45%; left: 50%; }
  }
  @keyframes lupa-discovering-pulse {
    0%       { transform: scale(0.6); opacity: 0; }
    20%      { transform: scale(1.3); opacity: 1; }
    40%      { transform: scale(1);   opacity: 1; }
    85%      { opacity: 1; }
    100%     { opacity: 0; }
  }

  /* breathing — strong centered pulse over the document */
  .mode-breathing {
    top: 50%;
    left: 62%;
    transform: translate(-50%, -50%);
    animation: lupa-breathing 2.6s ease-in-out infinite;
  }
  @keyframes lupa-breathing {
    0%, 100% { transform: translate(-50%, -50%) scale(1);    opacity: 0.85; }
    50%      { transform: translate(-50%, -50%) scale(1.22); opacity: 1; }
  }

  /* monitoring — vertical sweep with lateral zigzag */
  .mode-monitoring {
    top: 12%;
    left: 45%;
    animation: lupa-monitoring 6s ease-in-out infinite;
  }
  @keyframes lupa-monitoring {
    0%   { top: 12%; left: 45%; }
    20%  { top: 30%; left: 52%; }
    40%  { top: 50%; left: 42%; }
    60%  { top: 70%; left: 50%; }
    80%  { top: 50%; left: 42%; }
    100% { top: 12%; left: 45%; }
  }

  /* === inline mode keyframes ===
     For tilt / focus / scan-loop, the animation is applied to .lupa-shape
     (only the lens + handle), so the inner glyph stays still — the agent
     looks AT the data, not WITH it. */

  /* tilt — handle wags like a tail; the lens (rotationally symmetric)
     stays put visually while the inner icon stays upright. */
  .mode-tilt .lupa-shape {
    transform-box: fill-box;
    transform-origin: center;
    animation: lupa-tilt 3.6s ease-in-out infinite;
  }
  @keyframes lupa-tilt {
    0%, 100% { transform: rotate(-7deg); }
    50%      { transform: rotate(7deg); }
  }

  /* focus — the lens scales around the static check, like zooming in. */
  .mode-focus .lupa-shape {
    transform-box: fill-box;
    transform-origin: center;
    animation: lupa-focus 2.4s ease-in-out infinite;
  }
  @keyframes lupa-focus {
    0%, 100% { transform: scale(1);    opacity: 0.9; }
    50%      { transform: scale(1.18); opacity: 1; }
  }

  /* scan-loop — the lupa orbits a stationary chart-$. */
  .mode-scan-loop .lupa-shape {
    animation: lupa-scan-loop 3.2s linear infinite;
  }
  @keyframes lupa-scan-loop {
    0%   { transform: translate(-3px, 0); }
    25%  { transform: translate(0, -2px); }
    50%  { transform: translate(3px, 0); }
    75%  { transform: translate(0, 2px); }
    100% { transform: translate(-3px, 0); }
  }

  /* idle — soft "agent is here" pulse (no inner icon, animate the wrapper) */
  .mode-idle {
    animation: lupa-idle 3.2s ease-in-out infinite;
  }
  @keyframes lupa-idle {
    0%, 100% { transform: scale(1);    opacity: 0.8; }
    50%      { transform: scale(1.07); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .kurio-lupa-animated,
    .kurio-lupa-animated svg,
    .kurio-lupa-animated .lupa-shape {
      animation: none !important;
      transform: none !important;
    }
    .kurio-lupa-animated { opacity: 0.7; }
    .mode-breathing { transform: translate(-50%, -50%) !important; }
    .kurio-lupa-animated svg { opacity: 1; }
  }
</style>

