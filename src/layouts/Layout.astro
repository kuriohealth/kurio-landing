---
import { getLangFromUrl, useTranslations, getLocalizedPath } from "../i18n/utils";

interface Props {
  title?: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const {
  title = t("meta.title"),
  description = t("meta.description"),
} = Astro.props;

const site = Astro.site?.toString() || "https://kurio.health";
const ogImage = new URL("/images/icon.png", site).href;
const canonicalUrl = new URL(Astro.url.pathname, site).href;
const altEsUrl = new URL(getLocalizedPath(Astro.url.pathname, "es"), site).href;
const altEnUrl = new URL(getLocalizedPath(Astro.url.pathname, "en"), site).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href={altEsUrl} />
    <link rel="alternate" hreflang="en" href={altEnUrl} />
    <link rel="alternate" hreflang="x-default" href={altEsUrl} />

    <!-- Open Graph (WhatsApp, LinkedIn, Facebook) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Kurio" />
    <meta property="og:locale" content={t("meta.locale")} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Kurio",
      "url": site,
      "description": description,
      "logo": ogImage,
    })} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="antialiased">
    <!-- PostHog -->
    <script>
      import posthog from "posthog-js";
      posthog.init(import.meta.env.PUBLIC_POSTHOG_KEY, {
        // api_host points to the reverse proxy (t.kurio.health) so
        // events are not blocked by ad blockers / privacy extensions.
        api_host: import.meta.env.PUBLIC_POSTHOG_HOST,
        // ui_host stays on PostHog's domain — clicking the link in any
        // captured event opens the PostHog UI directly, not the proxy.
        ui_host: "https://us.posthog.com",
        person_profiles: "identified_only",
      });
    </script>
    <slot />
  </body>
</html>

<style is:global>
  /* Order matters: brand tokens first (set CSS vars), then the UI
     kit (consumes those vars in semantic classes), then the project
     global styles. */
  @import "../styles/kurio-brand.css";
  @import "../styles/kurio-ui.css";
  @import "../styles/global.css";

  @theme inline {
    --font-sans: "Inter", system-ui, -apple-system, sans-serif;
  }
</style>
