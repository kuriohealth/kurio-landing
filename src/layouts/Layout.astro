---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Kurio — Agente de autorizaciones para hospitales",
  description = "Kurio ayuda a tu hospital a enviar autorizaciones completas a cada aseguradora desde la primera vez. Menos rechazos, cobro mas rapido.",
} = Astro.props;

const ogImage = new URL("/images/icon.png", Astro.site || "https://kurio.health").href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://kurio.health" />

    <!-- Open Graph (WhatsApp, LinkedIn, Facebook) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content="https://kurio.health" />
    <meta property="og:site_name" content="Kurio" />
    <meta property="og:locale" content="es_GT" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Kurio",
      "url": "https://kurio.health",
      "description": description,
      "logo": ogImage,
    })} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  @theme inline {
    --font-sans: "Inter", system-ui, -apple-system, sans-serif;
  }
</style>
